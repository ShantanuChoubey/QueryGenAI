datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// User Role classification matching RBAC matrix.
enum Role {
  ADMIN
  USER
}

/// Query Execution Status.
enum ExecutionStatus {
  PENDING
  SUCCESS
  FAILED
}

/// Supported Database Types in Workspace.
enum DatabaseType {
  POSTGRESQL
  MYSQL
  SQLITE
  SQLSERVER
  OTHER
}

/// Supported Relationship Types.
enum RelationshipType {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_ONE
  MANY_TO_MANY
}

/// The User table handles system profiles and verification parameters.
model User {
  id           String      @id @default(uuid()) @db.Uuid
  fullName     String
  email        String      @unique
  passwordHash String
  role         Role        @default(USER)
  isVerified   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  queries      Query[]
  auditLogs    AuditLog[]
  workspaces   Workspace[]
  savedQueries SavedQuery[]

  @@map("users")
}

/// Workspace is the top-level container for a user's database project.
model Workspace {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  description   String?        @db.Text
  databaseType  DatabaseType   @default(POSTGRESQL)
  userId        String         @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  queries       Query[]
  tables        Table[]
  relationships Relationship[]
  savedQueries  SavedQuery[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@map("workspaces")
}

/// Table represents a logical database table within a workspace schema.
model Table {
  id                String         @id @default(uuid()) @db.Uuid
  workspaceId       String         @db.Uuid
  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  description       String?        @db.Text
  columns           Column[]
  sourceRelationships Relationship[] @relation("SourceTable")
  targetRelationships Relationship[] @relation("TargetTable")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("tables")
}

/// Column represents a single field in a Table.
model Column {
  id                 String         @id @default(uuid()) @db.Uuid
  tableId            String         @db.Uuid
  table              Table          @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name               String
  dataType           String
  nullable           Boolean        @default(true)
  primaryKey         Boolean        @default(false)
  unique             Boolean        @default(false)
  defaultValue       String?
  sourceRelationships Relationship[] @relation("SourceColumn")
  targetRelationships Relationship[] @relation("TargetColumn")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([tableId, name])
  @@index([tableId])
  @@map("columns")
}

/// Relationship declares a foreign-key link between two tables in a workspace.
model Relationship {
  id               String           @id @default(uuid()) @db.Uuid
  workspaceId      String           @db.Uuid
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceTableId    String           @db.Uuid
  sourceTable      Table            @relation("SourceTable", fields: [sourceTableId], references: [id], onDelete: Cascade)
  sourceColumnId   String           @db.Uuid
  sourceColumn     Column           @relation("SourceColumn", fields: [sourceColumnId], references: [id], onDelete: Cascade)
  targetTableId    String           @db.Uuid
  targetTable      Table            @relation("TargetTable", fields: [targetTableId], references: [id], onDelete: Cascade)
  targetColumnId   String           @db.Uuid
  targetColumn     Column           @relation("TargetColumn", fields: [targetColumnId], references: [id], onDelete: Cascade)
  relationshipType RelationshipType @default(ONE_TO_MANY)
  createdAt        DateTime         @default(now())

  @@index([workspaceId])
  @@index([sourceTableId])
  @@index([targetTableId])
  @@map("relationships")
}

/// The Query table logs the user prompt, execution times, and chosen SQL.
model Query {
  id              String          @id @default(uuid()) @db.Uuid
  prompt          String          @db.Text
  selectedSQL     String?         @db.Text
  executionStatus ExecutionStatus @default(PENDING)
  executionTime   Int?
  userId          String          @db.Uuid
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId     String?         @db.Uuid
  workspace       Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  variants        QueryVariant[]

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@map("queries")
}

/// QueryVariant stores different SQL alternatives generated by the LLM.
model QueryVariant {
  id          String  @id @default(uuid()) @db.Uuid
  sql         String  @db.Text
  explanation String? @db.Text
  ranking     Int
  queryId     String  @db.Uuid
  query       Query   @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("query_variants")
}

/// AuditLog tracks administrative actions, authentications, and changes for security audits.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// SavedQuery stores user-curated SQL queries within a Workspace for later reuse.
model SavedQuery {
  id                    String   @id @default(uuid()) @db.Uuid
  workspaceId           String   @db.Uuid
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId                String   @db.Uuid
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  description           String?  @db.Text
  naturalLanguagePrompt String   @db.Text
  generatedSQL          String   @db.Text
  databaseType          String   @default("POSTGRESQL")
  tags                  String[] @default([])
  isFavorite            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([workspaceId, title])
  @@index([workspaceId])
  @@index([userId])
  @@index([isFavorite])
  @@map("saved_queries")
}
