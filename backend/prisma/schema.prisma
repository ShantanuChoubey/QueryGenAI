datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// User Role classification matching RBAC matrix.
enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

/// Query Execution Status.
enum ExecutionStatus {
  PENDING
  SUCCESS
  FAILED
}

/// The User table handles system profiles and verification parameters.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  fullName     String
  email        String     @unique
  passwordHash String
  role         Role       @default(VIEWER)
  isVerified   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  queries      Query[]
  auditLogs    AuditLog[]

  @@map("users")
}

/// The Query table logs the user prompt, execution times, and chosen SQL.
model Query {
  id              String          @id @default(uuid()) @db.Uuid
  prompt          String          @db.Text
  selectedSQL     String?         @db.Text
  executionStatus ExecutionStatus @default(PENDING)
  executionTime   Int? // Time in milliseconds
  userId          String          @db.Uuid
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  variants        QueryVariant[]

  @@index([userId])
  @@index([createdAt])
  @@map("queries")
}

/// QueryVariant stores different variations and evaluations generated by the LLM.
model QueryVariant {
  id          String  @id @default(uuid()) @db.Uuid
  sql         String  @db.Text
  explanation String? @db.Text
  ranking     Int
  queryId     String  @db.Uuid
  query       Query   @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("query_variants")
}

/// AuditLog tracks administrative actions, authentications, and changes for security audits.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
