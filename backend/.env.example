# Server configuration
PORT=5000
NODE_ENV=production

# Database configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/querygendb?schema=public"

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# AI / Large Language Model Integration
LLM_API_KEY=your_openrouter_api_key_here
# Optional: pin a specific OpenRouter model (e.g. google/gemma-2-9b-it:free)
# If unset, the backend automatically tries a chain of free models.
LLM_MODEL=

# Application metadata
APP_NAME=YourAppName
APP_URL=https://yourapp.com
